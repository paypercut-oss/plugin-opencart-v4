{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-payment" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fas fa-save"></i></button>
        <a href="{{ cancel }}" data-bs-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-light"><i class="fas fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible fade show"><i class="fas fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endif %}
    <div class="card">
      <div class="card-header">
        <i class="fas fa-pencil-alt"></i> {{ text_edit }}
      </div>
      <div class="card-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-payment">
          
          <!-- Tab Navigation - Bootstrap 5 -->
          <ul class="nav nav-tabs" id="paypercut-tabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link active" id="tab-api-tab" data-bs-toggle="tab" data-bs-target="#tab-api" type="button" role="tab"><i class="fas fa-key"></i> API Configuration</button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" id="tab-payment-tab" data-bs-toggle="tab" data-bs-target="#tab-payment" type="button" role="tab"><i class="fas fa-credit-card"></i> Payment Settings</button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" id="tab-webhooks-tab" data-bs-toggle="tab" data-bs-target="#tab-webhooks" type="button" role="tab"><i class="fas fa-bell"></i> Webhooks</button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" id="tab-general-tab" data-bs-toggle="tab" data-bs-target="#tab-general" type="button" role="tab"><i class="fas fa-cog"></i> General</button>
            </li>
          </ul>
          
          <div class="tab-content pt-3">
            
            <!-- API Configuration Tab -->
            <div class="tab-pane fade show active" id="tab-api" role="tabpanel">
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-api-key">
                  {{ entry_api_key }}
                  <span data-bs-toggle="tooltip" title="{{ help_api_key }}">
                    <i class="fas fa-question-circle"></i>
                  </span>
                </label>
                <div class="col-sm-10">
                  <div class="input-group">
                    <input type="text" name="payment_paypercut_api_key" value="{{ payment_paypercut_api_key }}" placeholder="sk_test_... or sk_live_..." id="input-api-key" class="form-control" required />
                    <button type="button" class="btn btn-info" onclick="testApiConnection()" data-bs-toggle="tooltip" title="Verify your API key is valid">
                      <i class="fas fa-plug"></i> {{ button_test_connection }}
                    </button>
                  </div>
                  {% if payment_paypercut_api_key %}
                    {% if payment_paypercut_mode == 'test' %}
                    <div class="form-text text-warning"><i class="fas fa-flask"></i> {{ text_mode_test }}</div>
                    {% elseif payment_paypercut_mode == 'live' %}
                    <div class="form-text text-success"><i class="fas fa-check-circle"></i> {{ text_mode_live }}</div>
                    {% elseif payment_paypercut_mode == 'unknown' %}
                    <div class="form-text text-danger"><i class="fas fa-exclamation-triangle"></i> {{ text_mode_unknown }}</div>
                    {% endif %}
                  {% endif %}
                  <div id="connection-status" class="mt-2"></div>
                  {% if error_api_key %}
                  <div class="text-danger">{{ error_api_key }}</div>
                  {% endif %}
                </div>
              </div>
              {% if payment_method_configs %}
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-payment-method-config">
                  {{ entry_payment_method_config }}
                  <span data-bs-toggle="tooltip" title="{{ help_payment_method_config }}">
                    <i class="fas fa-question-circle"></i>
                  </span>
                </label>
                <div class="col-sm-10">
                  <select name="payment_paypercut_payment_method_config" id="input-payment-method-config" class="form-select">
                    <option value="">Default (All Payment Methods)</option>
                    {% for config in payment_method_configs %}
                    {% if config.id == payment_paypercut_payment_method_config %}
                    <option value="{{ config.id }}" selected="selected">{{ config.name }}{% if config.description %} - {{ config.description }}{% endif %}</option>
                    {% else %}
                    <option value="{{ config.id }}">{{ config.name }}{% if config.description %} - {{ config.description }}{% endif %}</option>
                    {% endif %}
                    {% endfor %}
                  </select>
                  <div class="form-text"><i class="fas fa-info-circle"></i> {{ help_payment_method_config }}</div>
                </div>
              </div>
              {% endif %}
            </div>
            
            <!-- Payment Settings Tab -->
            <div class="tab-pane fade" id="tab-payment" role="tabpanel">
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-statement-descriptor">
                  {{ entry_statement_descriptor }}
                  <span data-bs-toggle="tooltip" title="{{ help_statement_descriptor }}">
                    <i class="fas fa-question-circle"></i>
                  </span>
                </label>
                <div class="col-sm-10">
                  <input type="text" name="payment_paypercut_statement_descriptor" value="{{ payment_paypercut_statement_descriptor }}" placeholder="YOUR STORE NAME" id="input-statement-descriptor" class="form-control" maxlength="22" style="text-transform: uppercase;" />
                  <div class="form-text"><i class="fas fa-info-circle"></i> {{ help_statement_descriptor }}</div>
                  <div class="form-text text-muted"><i class="fas fa-text-width"></i> <span id="char-count">{{ payment_paypercut_statement_descriptor|length }}</span>/22 characters</div>
                  <div id="statement-preview" class="mt-2 p-3 rounded" style="background: linear-gradient(135deg, rgb(27, 38, 63) 0%, rgb(27, 38, 63) 50%, rgb(230, 253, 83) 50%, rgb(230, 253, 83) 100%); color: white; font-family: monospace; box-shadow: 0 4px 12px rgba(27, 38, 63, 0.3);">
                    <div style="font-size: 11px; opacity: 0.9; margin-bottom: 5px;">BANK STATEMENT PREVIEW</div>
                    <strong style="font-size: 14px;">{{ text_statement_preview }}:</strong> <span id="preview-text" style="font-weight: bold; font-size: 14px;">{{ payment_paypercut_statement_descriptor|default('PAYPERCUT') }}</span>
                  </div>
                </div>
              </div>
              
              <div class="card mb-3">
                <div class="card-header">
                  <i class="fas fa-mobile-alt"></i> {{ text_wallet_settings }}
                </div>
                <div class="card-body">
                  <div class="row mb-3">
                    <label class="col-sm-2 col-form-label" for="input-google-pay">
                      <i class="fab fa-google"></i> {{ entry_google_pay }}
                      <span data-bs-toggle="tooltip" title="{{ help_google_pay }}">
                        <i class="fas fa-question-circle"></i>
                      </span>
                    </label>
                    <div class="col-sm-10">
                      <select name="payment_paypercut_google_pay" id="input-google-pay" class="form-select">
                        {% if payment_paypercut_google_pay %}
                        <option value="1" selected="selected">{{ text_enabled }}</option>
                        <option value="0">{{ text_disabled }}</option>
                        {% else %}
                        <option value="1">{{ text_enabled }}</option>
                        <option value="0" selected="selected">{{ text_disabled }}</option>
                        {% endif %}
                      </select>
                      <div class="form-text"><i class="fas fa-info-circle"></i> {{ help_google_pay }}</div>
                    </div>
                  </div>
                  <div class="row mb-3">
                    <label class="col-sm-2 col-form-label" for="input-apple-pay">
                      <i class="fab fa-apple"></i> {{ entry_apple_pay }}
                      <span data-bs-toggle="tooltip" title="{{ help_apple_pay }}">
                        <i class="fas fa-question-circle"></i>
                      </span>
                    </label>
                    <div class="col-sm-10">
                      <select name="payment_paypercut_apple_pay" id="input-apple-pay" class="form-select">
                        {% if payment_paypercut_apple_pay %}
                        <option value="1" selected="selected">{{ text_enabled }}</option>
                        <option value="0">{{ text_disabled }}</option>
                        {% else %}
                        <option value="1">{{ text_enabled }}</option>
                        <option value="0" selected="selected">{{ text_disabled }}</option>
                        {% endif %}
                      </select>
                      <div class="form-text"><i class="fas fa-info-circle"></i> {{ help_apple_pay }}</div>
                    </div>
                  </div>
                  <div class="row mb-3">
                    <label class="col-sm-2 col-form-label" for="input-checkout-mode">
                      <i class="fas fa-desktop"></i> {{ entry_checkout_mode }}
                      <span data-bs-toggle="tooltip" title="{{ help_checkout_mode }}">
                        <i class="fas fa-question-circle"></i>
                      </span>
                    </label>
                    <div class="col-sm-10">
                      <select name="payment_paypercut_checkout_mode" id="input-checkout-mode" class="form-select">
                        <option value="hosted" {% if payment_paypercut_checkout_mode == 'hosted' %}selected="selected"{% endif %}>{{ text_hosted }}</option>
                        <option value="embedded" {% if payment_paypercut_checkout_mode == 'embedded' %}selected="selected"{% endif %}>{{ text_embedded }}</option>
                      </select>
                      <div class="form-text"><i class="fas fa-info-circle"></i> {{ help_checkout_mode }}</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Webhooks Tab -->
            <div class="tab-pane fade" id="tab-webhooks" role="tabpanel">
              <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> <strong>What are webhooks?</strong>
                Webhooks allow Paypercut to automatically notify your store when payment events occur (successful payments, failures, refunds). This ensures your order statuses are always up-to-date.
              </div>
              
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">
                  {{ entry_webhook_url }}
                  <span data-bs-toggle="tooltip" title="This URL will receive notifications from Paypercut when payment events occur">
                    <i class="fas fa-question-circle"></i>
                  </span>
                </label>
                <div class="col-sm-10">
                  <div class="input-group">
                    <input type="text" value="{{ payment_paypercut_webhook_url }}" id="webhook-url" class="form-control" readonly />
                    <button type="button" class="btn btn-secondary" onclick="copyWebhookUrl()" data-bs-toggle="tooltip" title="Copy webhook URL to clipboard">
                      <i class="fas fa-copy"></i> Copy
                    </button>
                  </div>
                  <div class="form-text"><i class="fas fa-info-circle"></i> {{ text_webhook_info|raw }}</div>
                </div>
              </div>
              
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">Webhook Status</label>
                <div class="col-sm-10">
                  <div id="webhook-status">
                    {% if webhook_status.configured %}
                      <div class="card bg-success bg-opacity-10 border-success">
                        <div class="card-body">
                          <h5><span class="badge bg-success"><i class="fas fa-check"></i> {{ text_webhook_configured }}</span></h5>
                          <p class="mt-2"><i class="fas fa-check-circle"></i> {{ webhook_status.message }}</p>
                          {% if webhook_status.webhook_id %}
                            <p class="mt-1"><small><strong>Webhook ID:</strong> <code>{{ webhook_status.webhook_id }}</code></small></p>
                          {% endif %}
                          <button type="button" class="btn btn-danger btn-sm mt-2" onclick="deleteWebhook()" data-bs-toggle="tooltip" title="Remove webhook from Paypercut">
                            <i class="fas fa-trash"></i> {{ text_webhook_delete }}
                          </button>
                        </div>
                      </div>
                    {% else %}
                      <div class="card bg-warning bg-opacity-10 border-warning">
                        <div class="card-body">
                          <h5><span class="badge bg-warning text-dark"><i class="fas fa-exclamation-triangle"></i> {{ text_webhook_not_configured }}</span></h5>
                          <p class="mt-2"><i class="fas fa-info-circle"></i> {{ webhook_status.message }}</p>
                          <button type="button" class="btn btn-primary btn-sm mt-2" onclick="createWebhook()" data-bs-toggle="tooltip" title="Automatically create webhook in Paypercut">
                            <i class="fas fa-plus"></i> {{ text_webhook_create }}
                          </button>
                        </div>
                      </div>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
            
            <!-- General Settings Tab -->
            <div class="tab-pane fade" id="tab-general" role="tabpanel">
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-order-status">
                  {{ entry_order_status }}
                  <span data-bs-toggle="tooltip" title="Order status when payment is successful">
                    <i class="fas fa-question-circle"></i>
                  </span>
                </label>
                <div class="col-sm-10">
                  <select name="payment_paypercut_order_status_id" id="input-order-status" class="form-select">
                    {% for order_status in order_statuses %}
                    {% if order_status.order_status_id == payment_paypercut_order_status_id %}
                    <option value="{{ order_status.order_status_id }}" selected="selected">{{ order_status.name }}</option>
                    {% else %}
                    <option value="{{ order_status.order_status_id }}">{{ order_status.name }}</option>
                    {% endif %}
                    {% endfor %}
                  </select>
                  <div class="form-text"><i class="fas fa-info-circle"></i> The order status that will be set when a payment is completed successfully</div>
                </div>
              </div>
              
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-status">
                  {{ entry_status }}
                  <span data-bs-toggle="tooltip" title="Enable or disable Paypercut payment method">
                    <i class="fas fa-question-circle"></i>
                  </span>
                </label>
                <div class="col-sm-10">
                  <select name="payment_paypercut_status" id="input-status" class="form-select">
                    {% if payment_paypercut_status %}
                    <option value="1" selected="selected">{{ text_enabled }}</option>
                    <option value="0">{{ text_disabled }}</option>
                    {% else %}
                    <option value="1">{{ text_enabled }}</option>
                    <option value="0" selected="selected">{{ text_disabled }}</option>
                    {% endif %}
                  </select>
                  <div class="form-text"><i class="fas fa-info-circle"></i> Enable or disable this payment method on checkout</div>
                </div>
              </div>
              
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-sort-order">
                  {{ entry_sort_order }}
                  <span data-bs-toggle="tooltip" title="Display order on checkout page (lower numbers appear first)">
                    <i class="fas fa-question-circle"></i>
                  </span>
                </label>
                <div class="col-sm-10">
                  <input type="text" name="payment_paypercut_sort_order" value="{{ payment_paypercut_sort_order }}" placeholder="0" id="input-sort-order" class="form-control" />
                  <div class="form-text"><i class="fas fa-info-circle"></i> Payment methods are sorted by this value on the checkout page</div>
                </div>
              </div>
              
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-logging">
                  {{ entry_logging }}
                  <span data-bs-toggle="tooltip" title="Enable logging of API requests, webhooks, and errors">
                    <i class="fas fa-question-circle"></i>
                  </span>
                </label>
                <div class="col-sm-10">
                  <select name="payment_paypercut_logging" id="input-logging" class="form-select">
                    {% if payment_paypercut_logging %}
                    <option value="1" selected="selected">{{ text_enabled }}</option>
                    <option value="0">{{ text_disabled }}</option>
                    {% else %}
                    <option value="1">{{ text_enabled }}</option>
                    <option value="0" selected="selected">{{ text_disabled }}</option>
                    {% endif %}
                  </select>
                  <div class="form-text">
                    <i class="fas fa-info-circle"></i> When enabled, logs API requests, webhook events, and errors. 
                    <span class="text-warning"><strong>Warning:</strong> Logs may contain sensitive data. Disable in production unless debugging.</span>
                  </div>
                </div>
              </div>
              
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label">Logs & Debugging</label>
                <div class="col-sm-10">
                  <a href="{{ logs_url }}" class="btn btn-info" target="_blank">
                    <i class="fas fa-list-alt"></i> View Logs (Webhooks & Errors)
                  </a>
                  <div class="form-text"><i class="fas fa-info-circle"></i> View webhook events, API errors, and debug information</div>
                </div>
              </div>
            </div>
            
          </div><!-- /.tab-content -->
        </form>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript">
// Statement descriptor preview and character count
function updateStatementPreview() {
    var descriptor = document.getElementById('input-statement-descriptor').value.toUpperCase() || 'PAYPERCUT';
    var length = descriptor.length;
    
    document.getElementById('input-statement-descriptor').value = descriptor;
    document.getElementById('preview-text').textContent = descriptor;
    document.getElementById('char-count').textContent = length;
}

document.getElementById('input-statement-descriptor').addEventListener('keyup', updateStatementPreview);
updateStatementPreview();

// Test API connection
function testApiConnection() {
    var apiKey = document.getElementById('input-api-key').value;
    
    if (!apiKey) {
        alert('Please enter an API key first');
        return;
    }
    
    document.getElementById('connection-status').innerHTML = '<div class="alert alert-info"><i class="fas fa-spinner fa-spin"></i> Testing connection...</div>';
    
    fetch('index.php?route=extension/paypercut/payment/paypercut|testConnection&user_token={{ user_token }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'api_key=' + encodeURIComponent(apiKey)
    })
    .then(response => response.json())
    .then(json => {
        if (json.error) {
            document.getElementById('connection-status').innerHTML = 
                '<div class="alert alert-danger alert-dismissible fade show">' +
                '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                '<i class="fas fa-times-circle"></i> <strong>Connection Failed:</strong> ' + json.error +
                '</div>';
        } else if (json.success) {
            var html = '<div class="alert alert-success alert-dismissible fade show">' +
                '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                '<i class="fas fa-check-circle"></i> <strong>' + json.message + '</strong><br>' +
                '<strong>Mode:</strong> ' + json.mode.toUpperCase();
            
            if (json.account_name) {
                html += '<br><strong>Account:</strong> ' + json.account_name;
            }
            
            html += '</div>';
            document.getElementById('connection-status').innerHTML = html;
        }
    })
    .catch(error => {
        document.getElementById('connection-status').innerHTML = 
            '<div class="alert alert-danger alert-dismissible fade show">' +
            '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
            '<i class="fas fa-exclamation-triangle"></i> <strong>Error:</strong> ' + error +
            '</div>';
    });
}

// Copy webhook URL to clipboard
function copyWebhookUrl() {
    var webhookUrl = document.getElementById('webhook-url');
    webhookUrl.select();
    webhookUrl.setSelectionRange(0, 99999);
    navigator.clipboard.writeText(webhookUrl.value);
    alert('Webhook URL copied to clipboard!');
}

// Create webhook via API
function createWebhook() {
    if (!confirm('This will create a webhook in your Paypercut account with all events enabled. Continue?')) {
        return;
    }
    
    document.getElementById('webhook-status').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating webhook...';
    
    fetch('index.php?route=extension/paypercut/payment/paypercut|createWebhook&user_token={{ user_token }}', {
        method: 'POST'
    })
    .then(response => response.json())
    .then(json => {
        if (json.error) {
            alert('Error: ' + json.error);
        } else if (json.success) {
            alert(json.success);
        }
        location.reload();
    })
    .catch(error => {
        alert('Error creating webhook: ' + error);
        location.reload();
    });
}

// Delete webhook via API
function deleteWebhook() {
    if (!confirm('This will delete the webhook from your Paypercut account. You can recreate it at any time. Continue?')) {
        return;
    }
    
    document.getElementById('webhook-status').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Deleting webhook...';
    
    fetch('index.php?route=extension/paypercut/payment/paypercut|deleteWebhook&user_token={{ user_token }}', {
        method: 'POST'
    })
    .then(response => response.json())
    .then(json => {
        if (json.error) {
            alert('Error: ' + json.error);
        } else if (json.success) {
            alert(json.success);
        }
        location.reload();
    })
    .catch(error => {
        alert('Error deleting webhook: ' + error);
        location.reload();
    });
}
</script>
{{ footer }}
