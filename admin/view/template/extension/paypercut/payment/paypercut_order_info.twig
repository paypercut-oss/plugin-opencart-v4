{% if has_transaction %}
<div class="card mb-3">
  <div class="card-header">
    <h5 class="card-title mb-0">
      <i class="fas fa-credit-card"></i> Paypercut Payment Information
    </h5>
  </div>
  <div class="card-body">
    
    <!-- Transaction Details -->
    <table class="table table-bordered">
      <tbody>
        <tr>
          <td style="width: 30%;"><strong>Transaction ID</strong></td>
          <td>
            <code>{{ transaction.payment_id }}</code>
            <a href="{{ paypercut_dashboard_url }}" target="_blank" class="btn btn-sm btn-info ms-2">
              <i class="fas fa-external-link-alt"></i> View in Dashboard
            </a>
          </td>
        </tr>
        <tr>
          <td><strong>Payment Status</strong></td>
          <td>
            {% if transaction.status == 'succeeded' %}
              <span class="badge bg-success"><i class="fas fa-check-circle"></i> Succeeded</span>
            {% elseif transaction.status == 'pending' %}
              <span class="badge bg-warning text-dark"><i class="fas fa-clock"></i> Pending</span>
            {% elseif transaction.status == 'failed' %}
              <span class="badge bg-danger"><i class="fas fa-times-circle"></i> Failed</span>
            {% else %}
              <span class="badge bg-secondary">{{ transaction.status|capitalize }}</span>
            {% endif %}
          </td>
        </tr>
        <tr>
          <td><strong>Payment Method</strong></td>
          <td>
            <i class="fas fa-credit-card"></i> {{ payment_method_formatted }}
          </td>
        </tr>
        <tr>
          <td><strong>Amount</strong></td>
          <td><strong>{{ transaction.amount|number_format(2) }} {{ transaction.currency }}</strong></td>
        </tr>
        {% if transaction.paypercut_customer_id %}
        <tr>
          <td><strong>Paypercut Customer ID</strong></td>
          <td><code>{{ transaction.paypercut_customer_id }}</code></td>
        </tr>
        {% endif %}
        <tr>
          <td><strong>Payment Date</strong></td>
          <td>{{ transaction.created_at }}</td>
        </tr>
        <tr>
          <td colspan="2">
            <button type="button" id="btn-view-details" class="btn btn-sm btn-secondary">
              <i class="fas fa-info-circle"></i> View Full Transaction Details
            </button>
          </td>
        </tr>
      </tbody>
    </table>
    
    <!-- Payment Actions for Uncaptured Payments -->
    {% if transaction.status == 'requires_capture' %}
    <hr>
    <div class="alert alert-warning">
      <i class="fas fa-exclamation-triangle"></i> <strong>Payment Authorization:</strong> This payment has been authorized but not yet captured. You must capture or cancel it.
    </div>
    
    <div class="btn-group" role="group">
      <button type="button" id="btn-capture-payment" class="btn btn-success">
        <i class="fas fa-check"></i> Capture Payment
      </button>
      <button type="button" id="btn-cancel-payment" class="btn btn-danger">
        <i class="fas fa-ban"></i> Cancel Payment
      </button>
    </div>
    
    <div id="payment-action-status" class="mt-3"></div>
    {% endif %}
    
    <!-- Refund Section -->
    {% if transaction.status == 'succeeded' %}
    <hr>
    <h5><i class="fas fa-undo"></i> Refund Management</h5>
    
    {% if refunds %}
    <div class="alert alert-info">
      <strong>Refund History:</strong>
      <ul class="mt-2 mb-2 ps-3">
        {% for refund in refunds %}
        <li>
          <strong>{{ refund.amount|number_format(2) }} {{ refund.currency }}</strong>
          - <code>{{ refund.refund_id }}</code>
          - 
          {% if refund.status == 'succeeded' %}
            <span class="badge bg-success">Succeeded</span>
          {% elseif refund.status == 'pending' %}
            <span class="badge bg-warning text-dark">Pending</span>
          {% elseif refund.status == 'failed' %}
            <span class="badge bg-danger">Failed</span>
          {% endif %}
          <br>
          <small class="text-muted">{{ refund.created_at }}{% if refund.reason %} - {{ refund.reason }}{% endif %}</small>
        </li>
        {% endfor %}
      </ul>
      <p class="mb-0 mt-2"><strong>Total Refunded:</strong> {{ total_refunded|number_format(2) }} {{ transaction.currency }}</p>
    </div>
    {% endif %}
    
    {% if can_refund %}
    <div id="refund-form">
      <div class="mb-3">
        <label class="form-label">Refund Type:</label>
        <div>
          <div class="form-check form-check-inline">
            <input type="radio" class="form-check-input" name="refund_type" value="partial" id="refund-partial" checked>
            <label class="form-check-label" for="refund-partial">Partial Refund</label>
          </div>
          <div class="form-check form-check-inline">
            <input type="radio" class="form-check-input" name="refund_type" value="full" id="refund-full">
            <label class="form-check-label" for="refund-full">Full Refund</label>
          </div>
        </div>
      </div>
      
      <div class="mb-3" id="refund-amount-group">
        <label class="form-label" for="refund-amount">Refund Amount ({{ transaction.currency }}):</label>
        <input type="number" class="form-control" id="refund-amount" step="0.01" min="0.01" max="{{ transaction.amount - total_refunded }}" placeholder="0.00" style="max-width: 200px;">
        <div class="form-text">Maximum refundable: {{ (transaction.amount - total_refunded)|number_format(2) }} {{ transaction.currency }}</div>
      </div>
      
      <div class="mb-3">
        <label class="form-label" for="refund-reason">Reason:</label>
        <select class="form-select" id="refund-reason" style="max-width: 300px;">
          <option value="requested_by_customer">Requested by Customer</option>
          <option value="duplicate">Duplicate Payment</option>
          <option value="fraudulent">Fraudulent Transaction</option>
        </select>
        <div class="form-text">Select the reason for this refund</div>
      </div>
      
      <div id="refund-status"></div>
      
      <button type="button" id="btn-process-refund" class="btn btn-danger">
        <i class="fas fa-undo"></i> Process Refund
      </button>
    </div>
    {% else %}
      {% if total_refunded >= transaction.amount %}
      <div class="alert alert-warning">
        <i class="fas fa-info-circle"></i> This payment has been fully refunded.
      </div>
      {% endif %}
    {% endif %}
    {% endif %}
    
  </div>
</div>

<!-- Transaction Details Modal -->
<div class="modal fade" id="transaction-details-modal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">
          <i class="fas fa-info-circle"></i> Full Transaction Details
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="transaction-details-content">
        <!-- Content loaded via AJAX -->
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
// Handle refund type toggle
$('input[name="refund_type"]').on('change', function() {
    if ($(this).val() === 'full') {
        $('#refund-amount-group').hide();
    } else {
        $('#refund-amount-group').show();
    }
});

// Process refund
$('#btn-process-refund').on('click', function() {
    var refundType = $('input[name="refund_type"]:checked').val();
    var refundAmount = parseFloat($('#refund-amount').val());
    var refundReason = $('#refund-reason').val();
    var isFull = refundType === 'full';
    
    // Validation
    if (!isFull && (!refundAmount || refundAmount <= 0)) {
        alert('Please enter a valid refund amount.');
        return;
    }
    
    if (!confirm('Are you sure you want to process this refund? This action cannot be undone.')) {
        return;
    }
    
    $('#refund-status').html('<div class="alert alert-info"><i class="fas fa-spinner fa-spin"></i> Processing refund...</div>');
    $('#btn-process-refund').prop('disabled', true);
    
    $.ajax({
        url: 'index.php?route=extension/paypercut/payment/paypercut|refund&user_token={{ user_token }}',
        type: 'post',
        data: {
            order_id: {{ order_id }},
            refund_amount: refundAmount,
            refund_reason: refundReason,
            full_refund: isFull
        },
        dataType: 'json',
        success: function(json) {
            if (json.error) {
                $('#refund-status').html(
                    '<div class="alert alert-danger alert-dismissible fade show">' +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                    '<i class="fas fa-exclamation-circle"></i> <strong>Error:</strong> ' + json.error +
                    '</div>'
                );
                $('#btn-process-refund').prop('disabled', false);
            } else if (json.success) {
                $('#refund-status').html(
                    '<div class="alert alert-success alert-dismissible fade show">' +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                    '<i class="fas fa-check-circle"></i> <strong>Success:</strong> ' + json.success +
                    '<br><small>Refund ID: ' + json.refund_id + ' | Amount: ' + json.amount + ' {{ transaction.currency }}</small>' +
                    '</div>'
                );
                
                // Reload page after 2 seconds to show updated refund history
                setTimeout(function() {
                    location.reload();
                }, 2000);
            }
        },
        error: function(xhr, status, error) {
            $('#refund-status').html(
                '<div class="alert alert-danger alert-dismissible fade show">' +
                '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                '<i class="fas fa-exclamation-triangle"></i> <strong>Connection Error:</strong> ' + error +
                '</div>'
            );
            $('#btn-process-refund').prop('disabled', false);
        }
    });
});

// View transaction details
$('#btn-view-details').on('click', function() {
    var modal = new bootstrap.Modal(document.getElementById('transaction-details-modal'));
    modal.show();
    $('#transaction-details-content').html('<div class="text-center"><i class="fas fa-spinner fa-spin fa-3x"></i><p class="mt-2">Loading...</p></div>');
    
    $.ajax({
        url: 'index.php?route=extension/paypercut/paypercut/paypercut_order|getTransactionDetails&user_token={{ user_token }}&order_id={{ order_id }}',
        type: 'get',
        dataType: 'json',
        success: function(json) {
            if (json.error) {
                $('#transaction-details-content').html(
                    '<div class="alert alert-danger">' +
                    '<i class="fas fa-exclamation-circle"></i> ' + json.error +
                    '</div>'
                );
            } else if (json.success) {
                var html = '<table class="table table-bordered table-striped">';
                
                // Basic info
                html += '<tr><th colspan="2" class="table-info">Payment Information</th></tr>';
                html += '<tr><td style="width: 30%;"><strong>Payment ID</strong></td><td><code>' + json.payment.id + '</code></td></tr>';
                html += '<tr><td><strong>Status</strong></td><td>' + json.payment.status + '</td></tr>';
                html += '<tr><td><strong>Amount</strong></td><td>' + json.amount.toFixed(2) + ' ' + json.currency.toUpperCase() + '</td></tr>';
                
                // Fees and net amount
                if (json.fees !== undefined) {
                    html += '<tr><td><strong>Fees</strong></td><td>' + json.fees.toFixed(2) + ' ' + json.currency.toUpperCase() + '</td></tr>';
                    html += '<tr><td><strong>Net Amount</strong></td><td><strong>' + json.net_amount.toFixed(2) + ' ' + json.currency.toUpperCase() + '</strong></td></tr>';
                }
                
                // Capture status
                html += '<tr><td><strong>Captured</strong></td><td>' + (json.captured ? '<span class="badge bg-success">Yes</span>' : '<span class="badge bg-warning text-dark">No</span>') + '</td></tr>';
                
                if (json.capture_before) {
                    var captureDate = new Date(json.capture_before * 1000);
                    html += '<tr><td><strong>Capture Before</strong></td><td>' + captureDate.toLocaleString() + '</td></tr>';
                }
                
                // 3DS authentication
                if (json.three_d_secure) {
                    html += '<tr><th colspan="2" class="table-info">3D Secure Authentication</th></tr>';
                    html += '<tr><td><strong>Authenticated</strong></td><td>' + (json.three_d_secure.authenticated ? '<span class="badge bg-success">Yes</span>' : '<span class="badge bg-warning text-dark">No</span>') + '</td></tr>';
                    
                    if (json.three_d_secure.version) {
                        html += '<tr><td><strong>3DS Version</strong></td><td>' + json.three_d_secure.version + '</td></tr>';
                    }
                    
                    if (json.three_d_secure.result) {
                        html += '<tr><td><strong>Result</strong></td><td>' + json.three_d_secure.result + '</td></tr>';
                    }
                }
                
                // Payment method details
                if (json.payment.payment_method) {
                    html += '<tr><th colspan="2" class="table-info">Payment Method Details</th></tr>';
                    html += '<tr><td colspan="2"><pre class="mb-0">' + JSON.stringify(json.payment.payment_method, null, 2) + '</pre></td></tr>';
                }
                
                html += '</table>';
                
                $('#transaction-details-content').html(html);
            }
        },
        error: function() {
            $('#transaction-details-content').html(
                '<div class="alert alert-danger">' +
                '<i class="fas fa-exclamation-triangle"></i> Connection error' +
                '</div>'
            );
        }
    });
});

// Capture payment
$('#btn-capture-payment').on('click', function() {
    if (!confirm('Are you sure you want to capture this payment?')) {
        return;
    }
    
    $('#payment-action-status').html('<div class="alert alert-info"><i class="fas fa-spinner fa-spin"></i> Capturing payment...</div>');
    $('#btn-capture-payment').prop('disabled', true);
    $('#btn-cancel-payment').prop('disabled', true);
    
    $.ajax({
        url: 'index.php?route=extension/paypercut/payment/paypercut_order|capture&user_token={{ user_token }}',
        type: 'post',
        data: {
            order_id: {{ order_id }},
            capture_amount: 0 // Full amount
        },
        dataType: 'json',
        success: function(json) {
            if (json.error) {
                $('#payment-action-status').html(
                    '<div class="alert alert-danger alert-dismissible fade show">' +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                    '<i class="fas fa-exclamation-circle"></i> <strong>Error:</strong> ' + json.error +
                    '</div>'
                );
                $('#btn-capture-payment').prop('disabled', false);
                $('#btn-cancel-payment').prop('disabled', false);
            } else if (json.success) {
                $('#payment-action-status').html(
                    '<div class="alert alert-success alert-dismissible fade show">' +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                    '<i class="fas fa-check-circle"></i> <strong>Success:</strong> ' + json.success +
                    '</div>'
                );
                
                setTimeout(function() {
                    location.reload();
                }, 2000);
            }
        },
        error: function() {
            $('#payment-action-status').html(
                '<div class="alert alert-danger">' +
                '<i class="fas fa-exclamation-triangle"></i> Connection error' +
                '</div>'
            );
            $('#btn-capture-payment').prop('disabled', false);
            $('#btn-cancel-payment').prop('disabled', false);
        }
    });
});

// Cancel payment
$('#btn-cancel-payment').on('click', function() {
    var reason = prompt('Please enter a reason for canceling this payment (optional):');
    
    if (reason === null) {
        return; // User clicked cancel
    }
    
    if (!confirm('Are you sure you want to cancel this payment? This action cannot be undone.')) {
        return;
    }
    
    $('#payment-action-status').html('<div class="alert alert-info"><i class="fas fa-spinner fa-spin"></i> Canceling payment...</div>');
    $('#btn-capture-payment').prop('disabled', true);
    $('#btn-cancel-payment').prop('disabled', true);
    
    $.ajax({
        url: 'index.php?route=extension/paypercut/payment/paypercut_order|cancel&user_token={{ user_token }}',
        type: 'post',
        data: {
            order_id: {{ order_id }},
            cancel_reason: reason
        },
        dataType: 'json',
        success: function(json) {
            if (json.error) {
                $('#payment-action-status').html(
                    '<div class="alert alert-danger alert-dismissible fade show">' +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                    '<i class="fas fa-exclamation-circle"></i> <strong>Error:</strong> ' + json.error +
                    '</div>'
                );
                $('#btn-capture-payment').prop('disabled', false);
                $('#btn-cancel-payment').prop('disabled', false);
            } else if (json.success) {
                $('#payment-action-status').html(
                    '<div class="alert alert-success alert-dismissible fade show">' +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                    '<i class="fas fa-check-circle"></i> <strong>Success:</strong> ' + json.success +
                    '</div>'
                );
                
                setTimeout(function() {
                    location.reload();
                }, 2000);
            }
        },
        error: function() {
            $('#payment-action-status').html(
                '<div class="alert alert-danger">' +
                '<i class="fas fa-exclamation-triangle"></i> Connection error' +
                '</div>'
            );
            $('#btn-capture-payment').prop('disabled', false);
            $('#btn-cancel-payment').prop('disabled', false);
        }
    });
});

</script>

{% else %}
<!-- No Paypercut transaction found for this order -->
{% endif %}
