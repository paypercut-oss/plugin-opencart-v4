{{ header }}
<div class="container">
  <ul class="breadcrumb">
    <li><a href="{{ continue }}">{{ text_home }}</a></li>
    <li><a href="#">{{ heading_title }}</a></li>
  </ul>
  <div class="row">
    <div id="content" class="col-sm-12">
      <h1>{{ heading_title }}</h1>
      
      <div class="alert alert-danger" style="padding: 30px; margin: 30px 0;">
        <div style="text-align: center;">
          <i class="fa fa-times-circle" style="font-size: 80px; color: #d9534f; margin-bottom: 20px;"></i>
          <h2 style="margin-bottom: 10px;">Payment Failed</h2>
          <p style="font-size: 16px; color: #555;">{{ text_message }}</p>
          
          {% if payment_id %}
          <div style="margin-top: 20px; padding: 15px; background: white; border-radius: 5px; display: inline-block;">
            <p style="margin: 0; font-size: 13px; color: #999;">Transaction Reference</p>
            <p style="margin: 5px 0 0 0; font-family: monospace; font-size: 14px; color: #333;">{{ payment_id }}</p>
          </div>
          {% endif %}
          
          <div style="margin-top: 25px; padding: 15px; background: #fff3cd; border-radius: 5px; border-left: 4px solid #ffc107;">
            <p style="margin: 0; font-size: 14px; color: #856404;">
              <i class="fa fa-info-circle"></i> <strong>What can you do?</strong>
            </p>
            <ul style="text-align: left; margin: 10px 0 0 20px; font-size: 13px; color: #856404;">
              <li>Check your card details and try again</li>
              <li>Try a different payment method</li>
              <li>Contact your bank if the issue persists</li>
              <li>Contact us if you need assistance</li>
            </ul>
          </div>
        </div>
      </div>
      
      <div class="buttons clearfix">
        <div class="pull-left">
          <a href="{{ continue }}" class="btn btn-default">
            <i class="fa fa-home"></i> Return to Home
          </a>
        </div>
        <div class="pull-right">
          <a href="{{ retry }}" class="btn btn-primary">
            <i class="fa fa-refresh"></i> Try Again
          </a>
          <a href="{{ contact }}" class="btn btn-info" style="margin-left: 10px;">
            <i class="fa fa-envelope"></i> Contact Us
          </a>
        </div>
      </div>
      
      {{ content_bottom }}
    </div>
  </div>
</div>
{{ footer }}
